root = true

[*]
max_line_length = 80
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
indent_size = 2

[*.yaml]
indent_size = 2

[*.talon]
max_line_length = 110
column_width = 28
preserve_multiline = true

[*.talon-list]
column_width = 15
