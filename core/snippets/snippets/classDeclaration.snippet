name: classDeclaration
phrase: class
insertionScope: class | statement

$name.insertionFormatter: setting(user.code_class_formatter)
---

language: csharp | java
-
public class $name {
    $0
}
---

language: cpp | javascript | typescript | javascriptreact | typescriptreact
-
class $name {
    $0
}
---

language: python
-
class $name:
    $0
---
